@host = https://localhost:7185

### The API does not issue tokens — paste an externally-obtained JWT here.
### It must be signed with the shared Jwt:Key and carry the expected issuer/audience.
@token = PASTE_A_VALID_JWT_HERE

### List pets (requires a token)
GET {{host}}/api/pets?page=1&pageSize=20
Authorization: Bearer {{token}}

### Search pets via stored procedure (requires a token)
GET {{host}}/api/pets/search?term=lab
Authorization: Bearer {{token}}

### Get one pet
GET {{host}}/api/pets/1
Authorization: Bearer {{token}}

### Create a pet
POST {{host}}/api/pets
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Milo",
  "breed": "Beagle",
  "price": 420.00,
  "ageMonths": 6,
  "categoryId": 1
}

### Update a pet
PUT {{host}}/api/pets/1
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Rex",
  "breed": "German Shepherd",
  "price": 700.00,
  "ageMonths": 9,
  "status": 0,
  "categoryId": 1
}

### Delete a pet (requires the Admin role in the token)
DELETE {{host}}/api/pets/1
Authorization: Bearer {{token}}
