{
  "ConnectionStrings": {
    "PetShopDb": "Server=localhost;Database=PetShop;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Issuer": "PetShop.Api",
    "Audience": "PetShop.Clients",
    "Key": "CHANGE_ME_to_a_long_random_secret_at_least_32_chars_long!!",
    "AccessTokenMinutes": 60
  },
  "Database": {
    "ApplyMigrationsOnStartup": true,
    "SeedAdmin": true,
    "AdminPassword": "Admin#12345"
  },
  "Diagnostics": {
    "LayerTracing": {
      "Enabled": false,
      "Service": true,
      "Data": true,
      "IncludeArguments": false
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [{CorrelationId}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/petshop-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] [{CorrelationId}] {SourceContext}{NewLine}    {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*"
}
