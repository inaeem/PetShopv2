{
  "ConnectionStrings": {
    "PetShopDb": "Server=localhost;Database=PetShop;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Issuer": "PetShop.Api",
    "Audience": "PetShop.Clients",
    "Modulus": "__SET_RSA_PUBLIC_KEY_MODULUS_base64url__",
    "Exponent": "AQAB"
  },
  "PetSync": {
    "Enabled": false,
    "BaseUrl": "https://external-pet-service.example.com",
    "CreatePetPath": "/pets",
    "ServiceToken": "",
    "TimeoutSeconds": 10,
    "MaxRetries": 2,
    "RetryBaseDelayMs": 200
  },
  "Mail": {
    "Enabled": false,
    "Host": "smtp.example.com",
    "Port": 587,
    "UseSsl": true,
    "Username": "",
    "Password": "",
    "FromAddress": "no-reply@petshop.example.com",
    "FromName": "PetShop",
    "TimeoutSeconds": 10,
    "TemplatesPath": "EmailTemplates"
  },
  "FhirEndpoints": {
    "Endpoints": [
      {
        "Name": "Acme Provider API",
        "MetaDataUrl": "https://acme.example.com/fhir/metadata",
        "SwaggerUrl": "https://acme.example.com/swagger.json",
        "Url": "https://acme.example.com/fhir",
        "Type": "Provider"
      },
      {
        "Name": "Acme Patient Portal",
        "MetaDataUrl": "https://patient.example.com/fhir/metadata",
        "SwaggerUrl": "https://patient.example.com/swagger.json",
        "Url": "https://patient.example.com/fhir",
        "Type": "Patient"
      }
    ]
  },
  "Database": {
    "ApplyMigrationsOnStartup": true
  },
  "Diagnostics": {
    "LayerTracing": {
      "Enabled": false,
      "Service": true,
      "Data": true,
      "IncludeArguments": false
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [{CorrelationId}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/petshop-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] [{CorrelationId}] {SourceContext}{NewLine}    {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*"
}
