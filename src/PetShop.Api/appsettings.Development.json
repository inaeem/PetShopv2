{
  "ConnectionStrings": {
    "PetShopDb": "Server=(localdb)\\MSSQLLocalDB;Database=PetShop;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft.AspNetCore": "Information"
      }
    }
  },
  "Diagnostics": {
    "LayerTracing": {
      "Enabled": true,
      "Service": true,
      "Data": true,
      "IncludeArguments": true
    }
  }
}
